# Free key, no credit card: https://console.groq.com/keys
GROQ_API_KEY=

# Groq retires models fairly often. If the app says the model is unavailable,
# pick a current one from https://console.groq.com/docs/models and set it here.
GROQ_MODEL=llama-3.3-70b-versatile

# Free M0 cluster: https://cloud.mongodb.com  (remember to allow 0.0.0.0/0 in
# Network Access, or Render won't be able to reach it)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ai-pair-programmer

# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

PORT=5000

# Comma separated. Add your Vercel URL here when you deploy.
ALLOWED_ORIGINS=http://localhost:5173

# Requests per minute, per IP. Groq's free tier is ~30/min, so stay under it.
RATE_LIMIT_MAX=20

# Run-button executions per minute, per IP. Wandbox and Piston are free and
# unmetered, but that's not an invitation.
RUN_RATE_LIMIT_MAX=15
